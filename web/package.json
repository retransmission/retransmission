{
  "name": "transmission-web",
  "main": "index.js",
  "repository": "https://github.com/transmissiontorrent/transmission",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "DEV=true node esbuild.mjs",
    "generate-buildonly": "node generate-buildonly.js",
    "lint": "run-p --silent lint:oxlint lint:stylelint lint:prettier",
    "lint:fix": "run-s lint:oxlint:fix lint:stylelint:fix lint:prettier:fix",
    "lint:oxlint": "oxlint",
    "lint:oxlint:fix": "oxlint --fix",
    "lint:prettier": "prettier --log-level warn --check .",
    "lint:prettier:fix": "prettier --log-level warn -w .",
    "lint:stylelint": "stylelint assets/css/*.css",
    "lint:stylelint:fix": "stylelint --fix assets/css/*.css"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
